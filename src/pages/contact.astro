---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import mapImg from '../assets/images/map.png';
---
<Layout title="Contact Us | JVE Kitchen Remodeling Pittsburgh" activePage="contact" description="Contact JVE Kitchen Remodeling Pittsburgh at (412) 267-9806. 401 Bingham St, Pittsburgh, PA 15203. Free estimates.">

<section class="page-hero">
  <div class="page-hero-inner">
    <span class="page-label">Contact Us</span>
    <h1>Let's Talk About<br />Your Kitchen</h1>
    <p class="page-hero-sub">Free estimates for all kitchen remodeling projects.</p>
  </div>
</section>

<section class="contact-main reveal">
  <div class="contact-main-inner">
    <div class="contact-info">
      <div class="contact-block">
        <h2>Call Us</h2>
        <a href="tel:4122679806" class="phone-large">(412) 267-9806</a>
      </div>

      <div class="contact-block">
        <h3>Email</h3>
        <a href="mailto:info@jvekitchenremodelingpittsburgh.com" class="email-link">info@jvekitchenremodelingpittsburgh.com</a>
      </div>

      <div class="contact-block">
        <h3>Address</h3>
        <address>
          401 Bingham St<br />
          Pittsburgh, PA 15203
        </address>
      </div>

      <div class="contact-block">
        <h3>Hours</h3>
        <p>Open 24/7</p>
      </div>

      <div class="contact-credentials">
        <span>PA Licensed and Insured</span>
        <span>Free Estimates</span>
      </div>
    </div>

    <div class="contact-map">
      <a href="https://www.google.com/maps/dir/?api=1&destination=401+Bingham+St+Pittsburgh+PA+15203"
         target="_blank" rel="noopener noreferrer" class="map-link">
        <Image src={mapImg} alt="Map showing JVE Kitchen Remodeling location at 401 Bingham St, Pittsburgh, PA" loading="lazy" width={800} height={500} class="map-image" />
        <div class="map-bar">
          <span>401 Bingham St, Pittsburgh</span>
          <span class="map-dir">Get directions &rarr;</span>
        </div>
      </a>
    </div>
  </div>
</section>

</Layout>

<style>
  .page-hero {
    padding: calc(var(--space-3xl) + 60px) var(--space-lg) var(--space-2xl);
    text-align: center;
    background: var(--color-bg-warm);
    border-bottom: 1px solid var(--color-border);
  }

  .page-hero-inner {
    max-width: 700px;
    margin: 0 auto;
  }

  .page-label {
    display: block;
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: var(--space-sm);
  }

  .page-hero h1 {
    font-family: var(--font-display), Georgia, serif;
    font-size: var(--font-size-3xl);
    color: var(--color-text);
    line-height: 1.05;
    margin-bottom: var(--space-md);
  }

  .page-hero-sub {
    font-size: var(--font-size-md);
    color: var(--color-text-muted);
  }

  .contact-main {
    padding: var(--space-2xl) var(--space-lg);
  }

  .contact-main-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  @media (min-width: 768px) {
    .contact-main-inner {
      grid-template-columns: 1fr 1.3fr;
    }
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .contact-block h2 {
    font-family: var(--font-display), Georgia, serif;
    font-size: var(--font-size-lg);
    color: var(--color-text);
    margin-bottom: var(--space-xs);
  }

  .contact-block h3 {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.25rem;
  }

  .phone-large {
    display: block;
    font-family: var(--font-display), Georgia, serif;
    font-size: var(--font-size-2xl);
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .phone-large:hover { opacity: 0.7; }

  .email-link {
    color: var(--color-text-muted);
    font-size: var(--font-size-base);
    transition: color 0.3s ease;
    text-decoration: none;
  }

  .email-link:hover { color: var(--color-accent); }

  .contact-block address,
  .contact-block p {
    color: var(--color-text-muted);
    font-style: normal;
    line-height: 1.7;
  }

  .contact-credentials {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .contact-credentials span {
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--color-accent);
    background: rgba(44, 95, 124, 0.08);
    padding: 0.35rem 0.8rem;
    border-radius: var(--border-radius);
  }

  .contact-map {
    border-radius: var(--border-radius);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .map-link {
    display: block;
    text-decoration: none;
  }

  .map-image {
    width: 100%;
    height: auto;
    display: block;
    transition: filter 0.3s ease;
  }

  .map-link:hover .map-image {
    filter: brightness(1.05);
  }

  .map-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-sm) var(--space-md);
    background: var(--color-bg-warm);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .map-dir {
    color: var(--color-accent);
    white-space: nowrap;
  }
</style>
